9ef-7bc6-492a-8ad3-f3939b6eae99__B160044812.jpg","description":"Natuurdocumentaire.","category":"Documentaire, Natuur"},"2988234":{"channel":"lgi-be-prod-master:natgeowild","start":"1626587700","end":"1626590400","first":"U","idtitle":"UNITEDVETSOFAMERICA","title":"United Vets of America","program_id":"crid:~~2F~~2Ftelenet.be~~2Fa03d4a88-cf86-4f40-99b1-aa1dc7ff8f64,imi:c2929607759612d8866c255365be5ca6263f2d2a","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/3ff__b79__3ffb79ef-7bc6-492a-8ad3-f3939b6eae99__B160044812.jpg","description":"Natuurdocumentaire.","category":"Documentaire, Natuur"},"2988661":{"channel":"lgi-be-prod-master:natgeowild","start":"1626590400","end":"1626593400","first":"B","idtitle":"BORNEOSSECRETKINGDOM","title":"Borneo's secret kingdom","program_id":"crid:~~2F~~2Ftelenet.be~~2F4bf6bd3f-0054-44c5-9626-52ca6081a4c3,imi:ad2fadfb581c68ae2b2bd2d2b3891ff41dc5836e","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/cf5__3ee__cf53ee54-c733-4e44-a6a6-7104e265ee50__B142621752.jpg","description":"De Kinabatangan-rivier kent stroomversnellingen, gaat door heuvels en in verdronken land. Maar het is het jaar van El Ni\u00f1o en de regen komt laat, wat zorgt voor hongersnood en droogte. Het leven kent hier veel uitdagingen, maar ook talrijke antwoorden daarop, gaande van de eigenaardige nesten van de neushoornvogel tot de junglevaardigheden van de orang-oetang. Op grillige stukken verdronken land leven olifanten, holbewoners en miniberen onder het bladerdak.","category":"Documentaire, Natuur"},"2989085":{"channel":"lgi-be-prod-master:natgeowild","start":"1626593400","end":"1626595800","first":"S","idtitle":"SECRETSOFTHEZOOTAMPA","title":"Secrets of The Zoo: Tampa","program_id":"crid:~~2F~~2Ftelenet.be~~2F1cad5ddd-808e-48ff-bd84-6ce8009b2315,imi:5866806c7582b7e2cc11cc9ab04893c9a343a113","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/3ff__b79__3ffb79ef-7bc6-492a-8ad3-f3939b6eae99__B160044812.jpg","description":"Het is lente in ZooTampa en veel dieren komen uit hun winterslaap. Er wordt een berenwelp afgegeven. Een maki heeft last van voorjaarsallergie\u00ebn. En een training met luiaards vraagt veel geduld.","category":"Documentaire, Natuur"},"2989218":{"channel":"lgi-be-prod-master:natgeowild","start":"1626595800","end":"1626598500","first":"S","idtitle":"SECRETSOFTHEZOOTAMPA","title":"Secrets of The Zoo: Tampa","program_id":"crid:~~2F~~2Ftelenet.be~~2F4ff5751d-c28d-45b7-a152-7b88b9cb818e,imi:0aeb1697f8f3326584a254120776a9dbf82dd9fb","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/3ff__b79__3ffb79ef-7bc6-492a-8ad3-f3939b6eae99__B160044812.jpg","description":"Babykoorts in ZooTampa! De pingu\u00efns Rocky en Thumbelina broeden op twee eieren. Twee Maleise tijgers gaan paren. En dokter Ray redt een rivierotter, die uiteindelijk weer terug de natuur in mag.","category":"Documentaire, Natuur"},"2989595":{"channel":"lgi-be-prod-master:natgeowild","start":"1626598500","end":"1626601200","first":"U","idtitle":"UNITEDVETSOFAMERICA","title":"United Vets of America","program_id":"crid:~~2F~~2Ftelenet.be~~2Fa03d4a88-cf86-4f40-99b1-aa1dc7ff8f64,imi:1a93daca8a8a44dbd9e5a16a52241bb3f4919265","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/3ff__b79__3ffb79ef-7bc6-492a-8ad3-f3939b6eae99__B160044812.jpg","description":"Natuurdocumentaire.","category":"Documentaire, Natuur"},"2989736":{"channel":"lgi-be-prod-master:natgeowild","start":"1626601200","end":"1626604200","first":"I","idtitle":"INDOCHINASWILDHEART","title":"Indochina's Wild Heart","program_id":"crid:~~2F~~2Ftelenet.be~~2Fa44acbc2-c77d-44b1-96a8-26c5132efc1a,imi:11375bf851d78580fcb08a8dbdbb448afed8901c","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/afe__b19__afeb19c6-21ba-4895-91b2-e0df9e41bbda__B154504537.jpg","description":"Het mystieke Cambodja is gevormd door de rivier de Mekong. Het door water gedomineerde land heeft de meest ongewone ecosystemen op aarde.","category":"Documentaire, Oude culturen"},"2990155":{"channel":"lgi-be-prod-master:natgeowild","start":"1626604200","end":"1626606900","first":"I","idtitle":"INDOCHINASWILDHEART","title":"Indochina's Wild Heart","program_id":"crid:~~2F~~2Ftelenet.be~~2Ffc6c659c-b026-44ff-b9c0-9decdb5a44de,imi:99527618537e6afc9e8e1814e53189775b119ebe","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/afe__b19__afeb19c6-21ba-4895-91b2-e0df9e41bbda__B154504537.jpg","description":"Vietnam is een van de meest biodiverse plaatsen op de planeet. Ontdek enkele van de unieke dierensoorten waarvan dit land de thuisbasis is.","category":"Documentaire, Oude culturen"},"2990554":{"channel":"lgi-be-prod-master:natgeowild","start":"1626606900","end":"1626609600","first":"L","idtitle":"LOSTSHARKSOFEASTERISLAND","title":"Lost Sharks Of Easter Island","program_id":"crid:~~2F~~2Ftelenet.be~~2F3286aec8-4a7a-4f3a-b21e-7a32dcc82e3b,imi:b92209179ac808199c1013ad63212c6ee62ace41","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/f7d__918__f7d9182e-b028-4dd9-892b-a84bcae1f003__B111411495.jpg","description":"Enric Sala en zijn team trotseren de woeste Stille Zuidzee, waar ze behalve enorme stenen beelden ook een woestijn onder water aantreffen.","category":"Documentaire, Natuur"},"2990703":{"channel":"lgi-be-prod-master:natgeowild","start":"1626609600","end":"1626612600","first":"M","idtitle":"MANVSSHARK","title":"Man vs. Shark","program_id":"crid:~~2F~~2Ftelenet.be~~2F06c6c847-118f-42b1-ae2e-1a44f3e1da35,imi:ecf4a563b7d716247301db0203b6e797b6d03531","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/f14__de0__f14de018-9dd6-491e-8f14-8ef0f728ccbd__B78363348.jpg","description":"E\u00e9n man, \u00e9\u00e9n haai, geen kooien. Kijk mee met de missie van Jeremiah Sullivans die al 50 jaar lang zwemt met haaien en zich inzet voor deze beruchte roofvissen.","category":"Documentaire, Natuur"},"2991118":{"channel":"lgi-be-prod-master:natgeowild","start":"1626612600","end":"1626615300","first":"O","idtitle":"OPERATIONSHARKLIFT","title":"Operation Sharklift","program_id":"crid:~~2F~~2Ftelenet.be~~2F17b44e7a-ed35-433f-ac07-90ab11d2428e,imi:7723bec59fc8d2f20d63205bb03d3c28558c0df2","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/f14__de0__f14de018-9dd6-491e-8f14-8ef0f728ccbd__B78363348.jpg","description":"Wetenschappers slagen erin om enorme stierhaaien te vangen en te vervoeren van de drukke haven in Noum\u00e9a naar een ongerept koraalrif, ver weg van de mensen.","category":"Documentaire, Natuur"},"2991266":{"channel":"lgi-be-prod-master:natgeowild","start":"1626615300","end":"1626618000","first":"S","idtitle":"SHARKKILLZONETHEHUNT","title":"Shark Kill Zone : The Hunt","program_id":"crid:~~2F~~2Ftelenet.be~~2F35260d83-4c09-4bd7-81a0-1955caa39a55,imi:13228061bb149fd0b6c315d501fcb77cfb9f1468","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/e32__e18__e32e1806-f1f1-48a3-a020-21511415d279__B144831552.jpg","description":"Documentaire (2018) over haaien","category":"Documentaire, Natuur"},"3001952":{"channel":"lgi-be-prod-master:natgeowild","start":"1626618000","end":"1626621000","first":"S","idtitle":"SHARKATTACKEXPERIMENT","title":"Shark Attack Experiment","program_id":"crid:~~2F~~2Ftelenet.be~~2F7d2bc39f-bc01-4b59-9414-6889abe86aca,imi:29bba7ca92da895dc2b040b5e881298e27a071c4","date":"","icon":"https:\/\/staticqbr-be-prod.tnprod.cdn.dmdsdp.com\/image-service\/ImagesEPG\/EventImages\/e02__11b__e0211b5e-9531-4bd3-bf00-cf63750c67d7__B172322757.jpg","description":"